# ── 키움증권 모의투자 ──────────────────────────
KIWOOM_MOCK_APP_KEY=your_mock_app_key
KIWOOM_MOCK_APP_SECRET=your_mock_app_secret
KIWOOM_MOCK_ACCOUNT_NO=your_mock_account_no

# ── 키움증권 실투자 ────────────────────────────
KIWOOM_REAL_APP_KEY=your_real_app_key
KIWOOM_REAL_APP_SECRET=your_real_app_secret
KIWOOM_REAL_ACCOUNT_NO=your_real_account_no

# ── 거래 모드 ──────────────────────────────────
# true = 모의투자, false = 실거래
IS_MOCK_TRADING=true

# ── 키움 공통 ──────────────────────────────────
KIWOOM_BASE_URL=https://openapi.kiwoom.com
KIWOOM_ACCOUNT_PRODUCT_CODE=01

# ── DB ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kiwoom:password@localhost:5432/kiwoom_trade
POSTGRES_DB=kiwoom_trade
POSTGRES_USER=kiwoom
POSTGRES_PASSWORD=change_this_password

# ── 인증 ───────────────────────────────────────
JWT_SECRET_KEY=generate_with_python_secrets_token_urlsafe_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── 암호화 (API 키 DB 저장용) ──────────────────
ENCRYPTION_KEY=generate_with_python_secrets_token_urlsafe_32

# ── CORS ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── LLM ──────────────────────────────────────────
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514
MAX_DAILY_LLM_COST_USD=5.0

# ── DART 공시 ────────────────────────────────────
DART_API_KEY=your_dart_api_key

# ── 텔레그램 알림 ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── 외부 데이터 API ────────────────────────────
FRED_API_KEY=your_fred_api_key
ECOS_API_KEY=your_ecos_api_key
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ── Cloudflare (추후) ──────────────────────────
# CLOUDFLARE_TUNNEL_TOKEN=

# ── Docker 환경 ────────────────────────────────
# Docker Compose로 실행 시 DATABASE_URL을 아래로 변경
# DATABASE_URL=postgresql+asyncpg://kiwoom:password@postgres:5432/kiwoom_trade

# ── Airflow ──────────────────────────────────
AIRFLOW_ADMIN_PASSWORD=changeme
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=changeme
AIRFLOW_DB_NAME=airflow
AIRFLOW_JWT_SECRET=generate_with_python_secrets_token_urlsafe_32
