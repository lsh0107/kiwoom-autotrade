# ============================================================
# 키움 자동매매 시스템 — 환경 변수 템플릿
# 복사 후 .env로 저장: cp .env.example .env
# ============================================================

# ── 실행 환경 ──────────────────────────────────
# development | production
APP_ENV=development

# ── 거래 모드 ──────────────────────────────────
# true = 모의투자, false = 실거래 (주의!)
IS_MOCK_TRADING=true

# ── DB (개발: 로컬 Homebrew PG / 프로덕션: Docker PG) ──
# 개발용
DATABASE_URL=postgresql+asyncpg://kiwoom:password@localhost:5432/kiwoom_trade
# 프로덕션용 (Docker Compose 내부)
# DATABASE_URL=postgresql+asyncpg://kiwoom:STRONG_PASSWORD@postgres:5432/kiwoom_trade

# Docker Compose PG (프로덕션 전용)
POSTGRES_DB=kiwoom_trade
POSTGRES_USER=kiwoom
POSTGRES_PASSWORD=change_this_password

# ── 키움증권 모의투자 ──────────────────────────
KIWOOM_MOCK_APP_KEY=
KIWOOM_MOCK_APP_SECRET=
KIWOOM_MOCK_ACCOUNT_NO=

# ── 키움증권 실투자 ────────────────────────────
KIWOOM_REAL_APP_KEY=
KIWOOM_REAL_APP_SECRET=
KIWOOM_REAL_ACCOUNT_NO=

# ── 키움 공통 ──────────────────────────────────
KIWOOM_BASE_URL=https://openapi.kiwoom.com
KIWOOM_ACCOUNT_PRODUCT_CODE=01

# ── 인증 ───────────────────────────────────────
# 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── 암호화 (API 키 DB 저장용) ──────────────────
# 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=

# ── CORS ───────────────────────────────────────
# 개발: http://localhost:3000 / 프로덕션: 실제 도메인
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── LLM ────────────────────────────────────────
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514
MAX_DAILY_LLM_COST_USD=5.0

# ── DART 공시 ──────────────────────────────────
DART_API_KEY=

# ── 알림 (추후) ────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Cloudflare (추후) ──────────────────────────
# CLOUDFLARE_TUNNEL_TOKEN=
