# 키움증권 REST API 설정
KIWOOM_APP_KEY=your_app_key_here
KIWOOM_APP_SECRET=your_app_secret_here

# 거래 모드 (true = 모의투자, false = 실거래)
IS_MOCK_TRADING=true

# 모의투자 API URL
KIWOOM_MOCK_BASE_URL=https://openapivts.koreainvestment.com:29443
# 실거래 API URL
KIWOOM_REAL_BASE_URL=https://openapi.koreainvestment.com:9443

# 계좌 정보
KIWOOM_ACCOUNT_NO=your_account_number
KIWOOM_ACCOUNT_PRODUCT_CODE=01

# 알림 설정 (선택)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
