{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI (로컬)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["src.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "env": {
        "IS_MOCK_TRADING": "true"
      },
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Trading Engine (로컬)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.engine.main",
      "env": {
        "IS_MOCK_TRADING": "true"
      },
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Pytest (전체)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v", "--tb=short"],
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Pytest (현재 파일)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v", "--tb=short"],
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Docker: FastAPI (Attach, 프로덕션)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "/app"
        }
      ],
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (로컬)",
      "configurations": ["FastAPI (로컬)", "Trading Engine (로컬)"]
    }
  ]
}
